{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": false,
        "jsx": "react-jsx"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "**/*.test.*",
        "**/*.spec.*",
        "**/*.stories.*"
    ]
}